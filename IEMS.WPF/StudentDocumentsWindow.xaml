<Window x:Class="IEMS.WPF.StudentDocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Documents" Height="560" Width="820"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}">
    <Border Style="{StaticResource CardStyle}" Margin="10">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="lblTitle" Grid.Row="0" Text="Documents" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>

            <!-- Toolbar -->
            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Document type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="cmbDocType" Width="170" Height="30" VerticalContentAlignment="Center" Margin="0,0,12,0"/>
                <Button x:Name="btnUploadFile" Content="Upload File" Width="120" Height="32" Margin="0,0,8,0"
                        Click="BtnUploadFile_Click" Style="{StaticResource SuccessButtonStyle}"/>
                <Button x:Name="btnUploadPhone" Content="Upload from Phone" Width="150" Height="32" Margin="0,0,8,0"
                        Click="BtnUploadPhone_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Separator Width="14"/>
                <Button x:Name="btnOpen" Content="Open" Width="90" Height="32" Margin="0,0,8,0"
                        Click="BtnOpen_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button x:Name="btnDelete" Content="Delete" Width="90" Height="32"
                        Click="BtnDelete_Click" Style="{StaticResource DangerButtonStyle}"/>
            </WrapPanel>

            <DataGrid x:Name="dgDocs" Grid.Row="2" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      MouseDoubleClick="DgDocs_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding DocumentType}" Width="160"/>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="80"/>
                    <DataGridTextColumn Header="Uploaded By" Binding="{Binding UploadedBy}" Width="110"/>
                    <DataGridTextColumn Header="Uploaded" Binding="{Binding FormattedDate}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock x:Name="lblStatus" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button x:Name="btnClose" Content="Close" Width="100" Height="32" Margin="20,0,0,0"
                        Click="BtnClose_Click" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
