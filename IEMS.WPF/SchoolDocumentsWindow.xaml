<Window x:Class="IEMS.WPF.SchoolDocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="School Documents" Height="600" Width="900"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BackgroundBrush}">
    <Border Style="{StaticResource CardStyle}" Margin="10">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="School Documents" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <TextBlock Grid.Row="1" Text="Store, open and share the school's own documents (affiliation papers, circulars, government letters, audit reports…). Files are kept in the database, so they're included in your backups."
                       TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>

            <!-- Toolbar -->
            <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="cmbDocType" Width="190" Height="30" VerticalContentAlignment="Center" Margin="0,0,12,0"/>
                <Button x:Name="btnUploadFile" Content="Upload File" Width="120" Height="32" Margin="0,0,8,0"
                        Click="BtnUploadFile_Click" Style="{StaticResource SuccessButtonStyle}"/>
                <Button x:Name="btnUploadPhone" Content="Upload from Phone" Width="150" Height="32" Margin="0,0,8,0"
                        Click="BtnUploadPhone_Click" Style="{StaticResource PrimaryButtonStyle}"
                        ToolTip="Show a QR code; scan it with a phone on the same Wi-Fi to upload a document"/>
                <Separator Width="14"/>
                <Button x:Name="btnOpen" Content="Open" Width="80" Height="32" Margin="0,0,8,0"
                        Click="BtnOpen_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                <Button x:Name="btnSendPhone" Content="Send to Phone" Width="120" Height="32" Margin="0,0,8,0"
                        Click="BtnSendPhone_Click" Style="{StaticResource PrimaryButtonStyle}"
                        ToolTip="Show a QR code to open this document on a phone (same Wi-Fi)"/>
                <Button x:Name="btnDelete" Content="Delete" Width="80" Height="32" Margin="0,0,16,0"
                        Click="BtnDelete_Click" Style="{StaticResource DangerButtonStyle}"/>
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="txtSearch" Width="170" Height="30" VerticalContentAlignment="Center"
                         TextChanged="TxtSearch_TextChanged"
                         ToolTip="Filter by file name or category"/>
            </WrapPanel>

            <DataGrid x:Name="dgDocs" Grid.Row="3" AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      AlternatingRowBackground="{StaticResource SurfaceBrush}"
                      MouseDoubleClick="DgDocs_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Category" Binding="{Binding DocumentType}" Width="180"/>
                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding FormattedSize}" Width="80"/>
                    <DataGridTextColumn Header="Uploaded By" Binding="{Binding UploadedBy}" Width="120"/>
                    <DataGridTextColumn Header="Uploaded" Binding="{Binding FormattedDate}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                <TextBlock x:Name="lblStatus" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button x:Name="btnClose" Content="Close" Width="100" Height="32" Margin="20,0,0,0"
                        Click="BtnClose_Click" Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
