<Window x:Class="IEMS.WPF.PhoneUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Photo from Phone" Width="420" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Background="{StaticResource SurfaceBrush}">
    <StackPanel Margin="24">
        <TextBlock Text="Upload / Scan Photo from Phone" FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
        <TextBlock x:Name="lblFor" Text="" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                   HorizontalAlignment="Center" Margin="0,2,0,14"/>

        <Border BorderBrush="#E0E4EC" BorderThickness="1" CornerRadius="10" Padding="12"
                Background="White" HorizontalAlignment="Center">
            <Image x:Name="imgQr" Width="220" Height="220" Stretch="Uniform"/>
        </Border>

        <TextBlock Text="1. Make sure the phone is on the SAME Wi-Fi as this PC."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,14,0,2" TextWrapping="Wrap"/>
        <TextBlock Text="2. Open the phone camera and point it at this QR code, then tap the link."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2" TextWrapping="Wrap"/>
        <TextBlock Text="3. Take or choose a photo and tap Upload."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <TextBlock Text="Or type this link in the phone's browser:" FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
        <TextBox x:Name="txtUrl" IsReadOnly="True" FontSize="12" Padding="6" Background="#F3F5F9"
                 BorderBrush="#E0E4EC" TextAlignment="Center"/>

        <TextBlock x:Name="lblStatus" Text="Waiting for the photo…" FontWeight="SemiBold"
                   Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,14,0,0"/>

        <Button x:Name="btnCancel" Content="Cancel" Width="120" Height="34" Margin="0,16,0,0"
                HorizontalAlignment="Center" Click="BtnCancel_Click"
                Style="{StaticResource SecondaryButtonStyle}"/>
    </StackPanel>
</Window>
