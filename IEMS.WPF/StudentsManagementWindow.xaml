<Window x:Class="IEMS.WPF.StudentsManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:IEMS.WPF.Controls"
        Title="Students Management" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- Main Content Grid -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}" Height="80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <Button x:Name="btnBack" Content="← Back"
                        Click="BtnBack_Click"
                        Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1"
                        Width="100" Height="35" Margin="0,0,20,0" FontWeight="SemiBold"/>
                <TextBlock Text="Students" FontSize="20" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource TextOnPrimaryBrush}"/>
                <TextBlock Text="Management System"
                           FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextOnPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Dashboard" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Overall Statistics Cards -->
                        <TextBlock Grid.Row="0" Text="📊 School Overview" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,15" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,30">
                            <!-- Total Students Card -->
                            <Border Background="{StaticResource SuccessBrush}" CornerRadius="10" Margin="5">
                                <StackPanel Margin="20" HorizontalAlignment="Center">
                                    <TextBlock Text="👥" FontSize="30" HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock x:Name="lblTotalStudents" Text="0" FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock Text="Total Students" FontSize="12" HorizontalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- Total Male Students Card -->
                            <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Margin="5">
                                <StackPanel Margin="20" HorizontalAlignment="Center">
                                    <TextBlock Text="👨‍🎓" FontSize="30" HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock x:Name="lblMaleStudents" Text="0" FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock Text="Male Students" FontSize="12" HorizontalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- Total Female Students Card -->
                            <Border Background="{StaticResource DangerBrush}" CornerRadius="10" Margin="5">
                                <StackPanel Margin="20" HorizontalAlignment="Center">
                                    <TextBlock Text="👩‍🎓" FontSize="30" HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock x:Name="lblFemaleStudents" Text="0" FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock Text="Female Students" FontSize="12" HorizontalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <!-- Total Classes Card -->
                            <Border Background="{StaticResource SecondaryBrush}" CornerRadius="10" Margin="5">
                                <StackPanel Margin="20" HorizontalAlignment="Center">
                                    <TextBlock Text="🏫" FontSize="30" HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock x:Name="lblTotalClasses" Text="0" FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" Foreground="White"/>
                                    <TextBlock Text="Total Classes" FontSize="12" HorizontalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Detailed Breakdown -->
                        <TextBlock Grid.Row="2" Text="📊 Detailed Breakdown" FontSize="18" FontWeight="Bold"
                                   Margin="0,0,0,15" Foreground="{StaticResource TextPrimaryBrush}"/>

                        <StackPanel Grid.Row="3">
                            <!-- BPL / Semi-English quick-stats strip -->
                            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Margin="5,0,5,10"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Margin="15,10">
                                    <TextBlock Text="🏠 BPL Students:" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="lblBPLStudents" Text="0" FontWeight="Bold" Margin="6,0,30,0"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="🌐 Semi-English:" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="lblSemiEnglishStudents" Text="0" FontWeight="Bold" Margin="6,0,0,0"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Balanced 2x2 grid of breakdown tables -->
                            <UniformGrid Columns="2">
                                <!-- Students per Class -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                        Margin="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Margin="15">
                                        <TextBlock Text="📈 Students per Class" FontSize="14" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <DataGrid x:Name="dgClassStats" AutoGenerateColumns="False" HeadersVisibility="Column"
                                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" MaxHeight="260"
                                                  GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                                  RowBackground="Transparent" AlternatingRowBackground="#F8F9FA">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="*"/>
                                                <DataGridTextColumn Header="Total" Binding="{Binding TotalStudents}" Width="60"/>
                                                <DataGridTextColumn Header="Male" Binding="{Binding MaleStudents}" Width="60"/>
                                                <DataGridTextColumn Header="Female" Binding="{Binding FemaleStudents}" Width="60"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Religion-wise -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                        Margin="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Margin="15">
                                        <TextBlock Text="🕉️ Religion-wise Breakdown" FontSize="14" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <DataGrid x:Name="dgReligionStats" AutoGenerateColumns="False" HeadersVisibility="Column"
                                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" MaxHeight="260"
                                                  GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                                  RowBackground="Transparent" AlternatingRowBackground="#F8F9FA">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Religion" Binding="{Binding Religion}" Width="*"/>
                                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                                                <DataGridTextColumn Header="Male" Binding="{Binding MaleCount}" Width="50"/>
                                                <DataGridTextColumn Header="Female" Binding="{Binding FemaleCount}" Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- Caste Category -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                        Margin="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Margin="15">
                                        <TextBlock Text="📊 Caste Category Breakdown" FontSize="14" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <DataGrid x:Name="dgCasteStats" AutoGenerateColumns="False" HeadersVisibility="Column"
                                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" MaxHeight="260"
                                                  GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                                  RowBackground="Transparent" AlternatingRowBackground="#F8F9FA">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                                                <DataGridTextColumn Header="Male" Binding="{Binding MaleCount}" Width="50"/>
                                                <DataGridTextColumn Header="Female" Binding="{Binding FemaleCount}" Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>

                                <!-- City/Village -->
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                                        Margin="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel Margin="15">
                                        <TextBlock Text="🏘️ City/Village Breakdown" FontSize="14" FontWeight="Bold"
                                                   Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <DataGrid x:Name="dgCityVillageStats" AutoGenerateColumns="False" HeadersVisibility="Column"
                                                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" MaxHeight="260"
                                                  GridLinesVisibility="Horizontal" BorderThickness="0" Background="Transparent"
                                                  RowBackground="Transparent" AlternatingRowBackground="#F8F9FA">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="City/Village" Binding="{Binding CityVillage}" Width="*"/>
                                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="60"/>
                                                <DataGridTextColumn Header="Male" Binding="{Binding MaleCount}" Width="50"/>
                                                <DataGridTextColumn Header="Female" Binding="{Binding FemaleCount}" Width="50"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Students" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
                        <Button x:Name="btnAddStudent" Content="+ Add Student" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnAddStudent_Click" Style="{StaticResource SuccessButtonStyle}"/>
                        <Button x:Name="btnEditStudent" Content="Edit Student" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnEditStudent_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="btnDeleteStudent" Content="Delete Student" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnDeleteStudent_Click" Style="{StaticResource DangerButtonStyle}"/>
                        <Button x:Name="btnStudentIdCard" Content="ID Card (PDF)" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnStudentIdCard_Click" Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Generate an ID card PDF for the selected student(s) — Ctrl/Shift-click to select several"/>
                        <Button x:Name="btnRefreshStudents" Content="Refresh" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnRefreshStudents_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="btnExportToExcel" Content="📊 Export to Excel" Width="150" Height="35" Margin="0,0,10,0"
                                Click="BtnExportToExcel_Click" Background="#28A745" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
                        <Button x:Name="btnViewStudentFees" Content="💰 View Fees" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnViewStudentFees_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Separator Width="20"/>
                        <TextBlock Text="Class:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <ComboBox x:Name="cmbStudentClassFilter" Width="150" Height="25" VerticalAlignment="Center"
                                 SelectionChanged="CmbStudentClassFilter_SelectionChanged"
                                 DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                                 ToolTip="Filter students by class"/>
                        <Separator Width="20"/>
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="10,0,10,0" FontSize="14"/>
                        <TextBox x:Name="txtSearchStudents" Width="250" Height="35" VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 TextChanged="TxtSearchStudents_TextChanged"
                                 ToolTip="Search by name, student number, father's name, or mobile number">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Button x:Name="btnClearStudentSearch" Content="Clear" Width="100" Height="35" Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>

                    <DataGrid x:Name="dgStudents" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" AlternatingRowBackground="{StaticResource SurfaceBrush}"
                              MouseDoubleClick="DgStudents_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Serial No" Binding="{Binding SerialNo}" Width="70"/>
                            <DataGridTextColumn Header="Standard" Binding="{Binding Standard}" Width="70"/>
                            <DataGridTextColumn Header="Division" Binding="{Binding ClassDivision}" Width="70"/>
                            <DataGridTextColumn Header="First Name" Binding="{Binding FirstName}" Width="100"/>
                            <DataGridTextColumn Header="Father's Name" Binding="{Binding FatherName}" Width="120"/>
                            <DataGridTextColumn Header="Surname" Binding="{Binding Surname}" Width="100"/>
                            <DataGridTextColumn Header="Date of Birth" Binding="{Binding FormattedDateOfBirth}" Width="90"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="70"/>
                            <DataGridTextColumn Header="Mother's Name" Binding="{Binding MotherName}" Width="120"/>
                            <DataGridTextColumn Header="Student No" Binding="{Binding StudentNumber}" Width="90"/>
                            <DataGridTextColumn Header="Admission Date" Binding="{Binding FormattedAdmissionDate}" Width="110"/>
                            <DataGridTextColumn Header="Caste Category" Binding="{Binding CasteCategory}" Width="110"/>
                            <DataGridTextColumn Header="Religion" Binding="{Binding Religion}" Width="80"/>
                            <DataGridTextColumn Header="BPL" Binding="{Binding IsBPL}" Width="50"/>
                            <DataGridTextColumn Header="Semi-English" Binding="{Binding IsSemiEnglish}" Width="100"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="150"/>
                            <DataGridTextColumn Header="Mobile" Binding="{Binding ParentMobileNumber}" Width="100"/>
                            <DataGridTextColumn Header="Aadhaar Number" Binding="{Binding AadhaarNumber}" Width="120"/>
                            <DataGridTextColumn Header="Outstanding Fees" Binding="{Binding FormattedOutstandingFees}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#E74C3C"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Classes" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
                        <Button x:Name="btnAddClass" Content="Add Class" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnAddClass_Click" Style="{StaticResource SuccessButtonStyle}"/>
                        <Button x:Name="btnEditClass" Content="Edit Class" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnEditClass_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="btnDeleteClass" Content="Delete Class" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnDeleteClass_Click" Style="{StaticResource DangerButtonStyle}"/>
                        <Button x:Name="btnRefreshClasses" Content="Refresh" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnRefreshClasses_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button x:Name="btnViewClassStudents" Content="View Students" Width="130" Height="35" Margin="10,0,10,0"
                                Click="BtnViewClassStudents_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>

                    <DataGrid x:Name="dgClasses" Grid.Row="1" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" AlternatingRowBackground="{StaticResource SurfaceBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Class" Binding="{Binding DisplayName}" Width="150"/>
                            <DataGridTextColumn Header="Class Teacher" Binding="{Binding TeacherName}" Width="200"/>
                            <DataGridTextColumn Header="Students Enrolled" Binding="{Binding StudentCount}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>


            <TabItem Header="Fee Management" FontSize="14">
                <TabControl>
                    <!-- Fee Payments Sub-tab -->
                    <TabItem Header="Fee Payments" FontSize="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
                                <Button x:Name="btnAddFeePayment" Content="+ Record Payment" Width="150" Height="35" Margin="0,0,10,0"
                                        Click="BtnAddFeePayment_Click" Style="{StaticResource SuccessButtonStyle}"/>
                                <Button x:Name="btnViewReceipt" Content="View Receipt" Width="130" Height="35" Margin="0,0,10,0"
                                        Click="BtnViewReceipt_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                                <Button x:Name="btnPrintReceipt" Content="Print Receipt" Width="130" Height="35" Margin="0,0,10,0"
                                        Click="BtnPrintReceipt_Click" Background="#9B59B6" Foreground="White" BorderThickness="0"/>
                                <Button x:Name="btnRefreshFeePayments" Content="Refresh" Width="130" Height="35" Margin="0,0,10,0"
                                        Click="BtnRefreshFeePayments_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                                <Separator Width="20"/>
                                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBox x:Name="txtSearchFeePayments" Width="200" Height="25" VerticalAlignment="Center"
                                         TextChanged="TxtSearchFeePayments_TextChanged"
                                         ToolTip="Search by receipt number, student name, or fee type"/>
                            </StackPanel>

                            <DataGrid x:Name="dgFeePayments" Grid.Row="1" AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column" AlternatingRowBackground="{StaticResource SurfaceBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Receipt No" Binding="{Binding ReceiptNumber}" Width="100"/>
                                    <DataGridTextColumn Header="Student Name" Binding="{Binding StudentName}" Width="150"/>
                                    <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="100"/>
                                    <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeTypeDisplay}" Width="100"/>
                                    <DataGridTextColumn Header="Amount Paid" Binding="{Binding AmountPaidFormatted}" Width="100"/>
                                    <DataGridTextColumn Header="Payment Method" Binding="{Binding PaymentMethodDisplay}" Width="120"/>
                                    <DataGridTextColumn Header="Payment Date" Binding="{Binding PaymentDateFormatted}" Width="100"/>
                                    <DataGridTextColumn Header="Remaining Balance" Binding="{Binding RemainingBalanceFormatted}" Width="120"/>
                                    <DataGridTextColumn Header="Academic Year" Binding="{Binding AcademicYear}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <!-- Fee Structure Sub-tab -->
                    <TabItem Header="Fee Structure" FontSize="12">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header Section -->
                            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20" Margin="0,0,0,20" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Fee Structure Management" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Configure fee amounts for different classes and fee types" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button x:Name="btnAddStudentFeeStructure" Content="Add Fee Structure"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Margin="0,0,10,0" Click="BtnAddStudentFeeStructure_Click" Height="35" Padding="15,0"/>
                                        <Button x:Name="btnEditStudentFeeStructure" Content="Edit Fee Structure"
                                                Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"
                                                Margin="0,0,10,0" Click="BtnEditStudentFeeStructure_Click" Height="35" Padding="10,0"/>
                                        <Button x:Name="btnDeleteStudentFeeStructure" Content="Delete Fee Structure"
                                                Style="{StaticResource DangerButtonStyle}" IsEnabled="False"
                                                Margin="0,0,10,0" Click="BtnDeleteStudentFeeStructure_Click" Height="35" Padding="10,0"/>
                                        <Button x:Name="btnRefreshStudentFeeStructures" Content="Refresh"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Click="BtnRefreshStudentFeeStructures_Click" Width="110" Height="35" Padding="10,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Filter Section -->
                            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,20" Padding="15" CornerRadius="5"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Academic Year Filter -->
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="Academic Year" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <ComboBox x:Name="cmbStudentFeeAcademicYear" Height="30"
                                                  SelectionChanged="CmbStudentFeeAcademicYear_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Class Filter -->
                                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                        <TextBlock Text="Class" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <ComboBox x:Name="cmbStudentFeeClassFilter" Height="30"
                                                  SelectionChanged="CmbStudentFeeClassFilter_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Fee Type Filter -->
                                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                        <TextBlock Text="Fee Type" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <ComboBox x:Name="cmbStudentFeeFeeTypeFilter" Height="30"
                                                  SelectionChanged="CmbStudentFeeFeeTypeFilter_SelectionChanged"/>
                                    </StackPanel>

                                    <!-- Search Box -->
                                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                        <TextBlock Text="Search" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBox x:Name="txtStudentFeeSearch" Height="30"
                                                 TextChanged="TxtStudentFeeSearch_TextChanged"
                                                 Tag="Search..."/>
                                    </StackPanel>

                                    <!-- Clear Filters Button -->
                                    <Button Grid.Column="4" x:Name="btnClearStudentFeeFilters"
                                            Content="Clear Filters"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            VerticalAlignment="Bottom" Height="30"
                                            Click="BtnClearStudentFeeFilters_Click"/>
                                </Grid>
                            </Border>

                            <!-- Data Grid -->
                            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                                <Grid>
                                    <DataGrid x:Name="dgStudentFeeStructures"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              GridLinesVisibility="Horizontal"
                                              HeadersVisibility="Column"
                                              AlternatingRowBackground="#F8F9FA"
                                              BorderThickness="0"
                                              SelectionMode="Single"
                                              SelectionChanged="DgStudentFeeStructures_SelectionChanged"
                                              MouseDoubleClick="DgStudentFeeStructures_MouseDoubleClick">

                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                            <DataGridTextColumn Header="Academic Year" Binding="{Binding AcademicYear}" Width="150"/>
                                            <DataGridTextColumn Header="Class" Binding="{Binding ClassName}" Width="200"/>
                                            <DataGridTextColumn Header="Fee Type" Binding="{Binding FeeType}" Width="150"/>
                                            <DataGridTextColumn Header="Amount (₹)" Binding="{Binding Amount, StringFormat='{}{0:N2}'}" Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextAlignment" Value="Right"/>
                                                        <Setter Property="Padding" Value="0,0,10,0"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Empty State -->
                                    <Border x:Name="studentFeeStructureEmptyStatePanel"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                                            <TextBlock Text="No Fee Structures Found"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,5"/>
                                            <TextBlock Text="Add fee structures to configure fees for classes"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
