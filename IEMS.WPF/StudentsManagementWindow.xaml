                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Summary Bar -->
                            <Border Grid.Row="3" Background="{StaticResource SecondaryDarkBrush}" CornerRadius="5" Padding="15,10">
