                                        <TextBlock x:Name="lblStudentTotalFeeAmount" Foreground="{StaticResource TextOnPrimaryBrush}" Text="Total Amount: ₹0.00"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="ID Cards" FontSize="14">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: search + student list + generate buttons -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox x:Name="txtSearchIdCard" Width="220" Height="28" VerticalContentAlignment="Center"
                                     TextChanged="TxtSearchIdCard_TextChanged"
                                     ToolTip="Search by name, roll number or class"/>
                            <TextBlock Text="Class:" VerticalAlignment="Center" Margin="15,0,5,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ComboBox x:Name="cmbIdCardTabClass" Width="130" Height="28" VerticalContentAlignment="Center"
                                      SelectionChanged="CmbIdCardTabClass_SelectionChanged"/>
                        </StackPanel>

                        <DataGrid x:Name="dgIdCardStudents" Grid.Row="1" AutoGenerateColumns="False"
                                  SelectionMode="Extended" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                  AlternatingRowBackground="{StaticResource SurfaceBrush}"
                                  SelectionChanged="DgIdCardStudents_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Roll No" Binding="{Binding StudentNumber}" Width="100"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                <DataGridTextColumn Header="Class" Binding="{Binding ClassWithDivision}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="btnIdCardGenerateSelected" Content="Generate ID Card (selected)" Width="220" Height="38" Margin="0,0,10,0"
                                    Click="BtnIdCardGenerateSelected_Click" Style="{StaticResource SuccessButtonStyle}"
                                    ToolTip="Ctrl/Shift-click to select several students"/>
                            <Button x:Name="btnIdCardGenerateClass" Content="Print Whole Class" Width="160" Height="38"
                                    Click="BtnIdCardGenerateClass_Click" Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="Print ID cards for every student in the class chosen above"/>
                        </StackPanel>
                    </Grid>

                    <!-- Right: selected student's photo + actions -->
                    <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="18">
                        <StackPanel>
                            <TextBlock x:Name="lblIdCardStudentName" Text="Select a student" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="lblIdCardStudentClass" Text="" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,14"/>

                            <Border Width="170" Height="210" HorizontalAlignment="Center"
                                    BorderBrush="#BDC3C7" BorderThickness="1" Background="White">
                                <Image x:Name="imgIdCardPhoto" Stretch="Uniform"/>
                            </Border>

                            <TextBlock Text="JPG or PNG, up to 2 MB" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,6,0,14"/>

                            <Button x:Name="btnIdCardChoosePhoto" Content="Add / Change Photo" Height="38" Margin="0,0,0,8"
                                    Click="BtnIdCardChoosePhoto_Click" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False"/>
                            <Button x:Name="btnIdCardRemovePhoto" Content="Remove Photo" Height="38"
                                    Click="BtnIdCardRemovePhoto_Click" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Bonafide" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,10">
                        <Button x:Name="btnGenerateBonafide" Content="Generate Certificate" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnGenerateBonafide_Click" Style="{StaticResource SuccessButtonStyle}"/>
                        <Button x:Name="btnGenerateIdCard" Content="ID Card (PDF)" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnGenerateIdCard_Click" Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Generate ID cards for the selected students (Ctrl/Shift-click to multi-select)"/>
                        <ComboBox x:Name="cmbIdCardClass" Width="130" Height="35" Margin="0,0,6,0" VerticalContentAlignment="Center"
                                  ToolTip="Pick a class to print all its ID cards"/>
                        <Button x:Name="btnClassIdCards" Content="Class ID Cards" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnClassIdCards_Click" Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button x:Name="btnRefreshBonafide" Content="Refresh" Width="130" Height="35" Margin="0,0,10,0"
                                Click="BtnRefreshBonafide_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                        <Separator Width="20"/>
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox x:Name="txtSearchBonafide" Width="200" Height="25" VerticalAlignment="Center"
                                 TextChanged="TxtSearchBonafide_TextChanged"
                                 ToolTip="Search by student name, student number, or class"/>
                    </StackPanel>

                    <DataGrid x:Name="dgBonafideStudents" Grid.Row="1" AutoGenerateColumns="False"
                              SelectionMode="Extended"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column" AlternatingRowBackground="{StaticResource SurfaceBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Student No" Binding="{Binding StudentNumber}" Width="100"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="200"/>
                            <DataGridTextColumn Header="Father's Name" Binding="{Binding FatherName}" Width="150"/>
                            <DataGridTextColumn Header="Mother's Name" Binding="{Binding MotherName}" Width="150"/>
                            <DataGridTextColumn Header="Class" Binding="{Binding ClassWithDivision}" Width="100"/>
                            <DataGridTextColumn Header="Date of Birth" Binding="{Binding FormattedDateOfBirth}" Width="100"/>
                            <DataGridTextColumn Header="Admission Date" Binding="{Binding FormattedAdmissionDate}" Width="110"/>
                            <DataGridTextColumn Header="Caste" Binding="{Binding CasteCategory}" Width="100"/>
                            <DataGridTextColumn Header="Religion" Binding="{Binding Religion}" Width="100"/>
                            <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Leaving Certificate Tab -->
            <TabItem Header="Leaving Certificate" FontSize="14">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel - Certificate Generation Form -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Margin="0,0,20,0">
                        <Border Background="White" BorderBrush="{StaticResource SecondaryBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="25">
                            <StackPanel>
                                <TextBlock Text="🎓 Generate Leaving Certificate" FontSize="18" FontWeight="Bold"
                                           Margin="0,0,0,20" Foreground="{StaticResource TextPrimaryBrush}"/>

                                <!-- Student Selection -->
                                <TextBlock Text="Select Student:" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbLeavingCertStudent" Margin="0,0,0,15" Height="35"
                                          DisplayMemberPath="FullNameWithAdmissionNumber"
                                          SelectionChanged="CmbLeavingCertStudent_SelectionChanged"/>

                                <!-- Student Details Grid -->
                                <Grid x:Name="gridLeavingCertDetails" Visibility="Collapsed" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Student Information Display -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Student Name:" FontWeight="Bold" Margin="0,5"/>
