                                        <Border Grid.Row="3" Grid.Column="3" BorderBrush="Black" BorderThickness="0,0,0,1" Height="15" Margin="0,5,0,0">
                                            <TextBlock x:Name="CertHeaderGeneralRegister" FontSize="10" Margin="5,0,0,0"/>
