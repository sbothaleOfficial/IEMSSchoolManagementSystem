                                    <TextBlock x:Name="lblStudentFeeStructureStatus" Foreground="{StaticResource TextOnPrimaryBrush}" Text="Ready"/>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock x:Name="lblStudentTotalFeeRecords" Foreground="{StaticResource TextOnPrimaryBrush}" Text="Total Records: 0"/>
